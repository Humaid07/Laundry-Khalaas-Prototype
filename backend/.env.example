APP_ENV=development
DEBUG=true
MOCK_LLM=true

# PostgreSQL — these match the postgres service in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://laundrykhalaas:laundrykhalaas_dev@postgres:5432/laundrykhalaas
POSTGRES_USER=laundrykhalaas
POSTGRES_PASSWORD=laundrykhalaas_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=laundrykhalaas

# Redis — matches the redis service in docker-compose.yml
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# LLM — leave ANTHROPIC_API_KEY blank; MOCK_LLM=true means no real API calls
ANTHROPIC_API_KEY=
ANTHROPIC_COMPLEX_MODEL=claude-sonnet-4-6
ANTHROPIC_ROUTINE_MODEL=claude-haiku-4-5-20251001

LLM_PER_MESSAGE_TOKEN_CAP=2000
LLM_CONVERSATION_TOKEN_CEILING=20000
